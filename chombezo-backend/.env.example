# Supabase Database Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here

# FastLipa Payment API Configuration
FASTLIPA_API_URL=https://fastlipa.co.tz/api
FASTLIPA_API_KEY=your-fastlipa-api-key-here

# JWT Authentication Secret
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-random-jwt-secret-here-minimum-32-characters

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Optional: Enable mock payments for testing (set to 'true' for development)
MOCK_PAYMENTS=false

# Node Environment
NODE_ENV=production
